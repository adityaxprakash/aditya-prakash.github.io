---
import CollectionLayout from '../../layouts/CollectionLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<CollectionLayout title="blog" heading="my thoughts" subtitle="writing about things i notice or read about.">
  {posts.map(p => (
  <li class="post-item">
    <a href={`/blog/${p.id}`}>{p.data.title}</a>
    {p.data.description && <p class="post-desc">{p.data.description}</p>}
    <div class="post-meta">
      <span class="post-date">{p.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day:
        'numeric' })}</span>
      {p.data.tags && (
      <div class="post-tags">
        {p.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      )}
    </div>
  </li>
  ))}
</CollectionLayout>