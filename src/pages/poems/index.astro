---
import CollectionLayout from '../../layouts/CollectionLayout.astro';
import { getCollection } from 'astro:content';

const poems = (await getCollection('poems', ({ data }) => !data.draft))
.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<CollectionLayout title="poems" heading="poems" subtitle="things i wrote when i felt something.">
  {poems.map(p => (
  <li class="post-item">
    <a href={`/poems/${p.id}`}>{p.data.title}</a>
    <div class="post-meta">
      <span class="post-date">{p.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day:
        'numeric' })}</span>
    </div>
  </li>
  ))}
</CollectionLayout>