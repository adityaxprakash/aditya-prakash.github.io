---
import Base from './Base.astro';

interface Props {
  title: string;
  heading: string;
  subtitle: string;
}

const { title, heading, subtitle } = Astro.props;
---

<Base title={title}>
  <section>
    <div class="section-header">
      <h2>{heading}</h2>
      <p>{subtitle}</p>
    </div>
    <ul class="post-list">
      <slot />
    </ul>
  </section>
</Base>

<style>
  section { margin-top: 0; }

  .section-header { margin-bottom: 2rem; }
  .section-header h2 { font-size: 32px; font-weight: 600; color: #e8e8e8; letter-spacing: -0.02em; margin-bottom: 0.3rem; }
  .section-header p { font-size: 14px; color: #444; }

  .post-list { list-style: none; padding: 0; }

  :global(.post-item) { display: flex; flex-direction: column; gap: 4px; padding: 0.9rem 0; border-bottom: 1px solid #2b2b2b; }
  :global(.post-item:first-child) { border-top: 1px solid #2b2b2b; }
  :global(.post-item a) { font-size: 20px; color: #eee; text-decoration: none; }
  :global(.post-item a:visited) { color: #eee; }
  :global(.post-item a:hover) { color: #fff; }
  :global(.post-desc) { font-size: 14px; color: #555; line-height: 1.6; }
  :global(.post-meta) { display: flex; gap: 12px; align-items: center; margin-top: 2px; }
  :global(.post-date) { font-size: 11px; color: #333; }
  :global(.post-tags) { display: flex; gap: 6px; }
  :global(.tag) { font-size: 10px; color: #3a3a3a; border: 1px solid #222; padding: 1px 6px; border-radius: 3px; }
</style>